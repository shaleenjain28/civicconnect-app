### Departments Page (NEW)
- Expandable department cards with HOD info
- Issue breakdown bars (Pending / In Progress / Verification / Resolved)
- Supervisor can edit HOD details inline
- Escalated issue count per department

```diff:DepartmentsPage.jsx
===
import React, { useState, useEffect } from 'react';
import { Building2, Phone, Mail, User, AlertTriangle, CheckCircle, Clock, ChevronRight, Edit3, Flag } from 'lucide-react';

export default function DepartmentsPage() {
  const [departments, setDepartments] = useState([]);
  const [selectedDept, setSelectedDept] = useState(null);
  const [loading, setLoading] = useState(true);
  const [editingHod, setEditingHod] = useState(null);
  const [hodForm, setHodForm] = useState({ hodName: '', hodEmail: '', hodPhone: '', hodTitle: '' });

  useEffect(() => {
    fetchDepartments();
  }, []);

  const fetchDepartments = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/departments');
      if (res.ok) {
        const data = await res.json();
        setDepartments(data);
      }
    } catch (err) {
      console.error('Failed to load departments:', err);
    } finally {
      setLoading(false);
    }
  };

  const handleHodSave = async (deptId) => {
    try {
      const session = JSON.parse(localStorage.getItem('cc_session') || '{}');
      const res = await fetch(`/api/departments/${deptId}/hod`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${session.access_token}`,
        },
        body: JSON.stringify(hodForm),
      });
      if (res.ok) {
        setEditingHod(null);
        fetchDepartments();
      } else {
        const err = await res.json();
        alert(err.error || 'Failed to update HOD');
      }
    } catch (err) {
      alert('Failed to save: ' + err.message);
    }
  };

  const startEditHod = (dept) => {
    setEditingHod(dept.id);
    setHodForm({
      hodName: dept.hodName || '',
      hodEmail: dept.hodEmail || '',
      hodPhone: dept.hodPhone || '',
      hodTitle: dept.hodTitle || '',
    });
  };

  const userRole = JSON.parse(localStorage.getItem('cc_user') || '{}')?.role;
  const isSupervisor = userRole === 'supervisor';

  return (
    <div className="page-content">
      <div className="page-header">
        <div>
          <h1 className="page-title">
            <Building2 size={24} />
            Departments
          </h1>
          <p className="page-subtitle">
            {departments.length} departments • HOD contacts & issue breakdown
          </p>
        </div>
      </div>

      {loading ? (
        <div className="loading-grid">
          {[1,2,3,4,5].map(i => (
            <div key={i} className="skeleton-card" style={{ height: 200 }} />
          ))}
        </div>
      ) : (
        <div className="dept-page-grid">
          {departments.map((dept) => (
            <div
              key={dept.id}
              className={`dept-page-card ${selectedDept === dept.id ? 'expanded' : ''}`}
              style={{ borderTopColor: dept.color }}
            >
              {/* Header */}
              <div className="dept-page-header" onClick={() => setSelectedDept(selectedDept === dept.id ? null : dept.id)}>
                <div className="dept-page-icon-wrap" style={{ background: dept.color + '20' }}>
                  <span className="dept-page-icon">{dept.icon}</span>
                </div>
                <div className="dept-page-info">
                  <h3 className="dept-page-name">{dept.name}</h3>
                  <p className="dept-page-desc">{dept.description}</p>
                </div>
                <ChevronRight size={20} className={`dept-chevron ${selectedDept === dept.id ? 'open' : ''}`} />
              </div>

              {/* Stats Row */}
              <div className="dept-page-stats">
                <div className="dept-stat" style={{ color: '#F59E0B' }}>
                  <Clock size={14} />
                  <span>{dept.pendingCount || 0} Pending</span>
                </div>
                <div className="dept-stat" style={{ color: '#3B82F6' }}>
                  <AlertTriangle size={14} />
                  <span>{dept.inProgressCount || 0} Active</span>
                </div>
                <div className="dept-stat" style={{ color: '#10B981' }}>
                  <CheckCircle size={14} />
                  <span>{dept.resolvedCount || 0} Resolved</span>
                </div>
                {(dept.escalatedCount || 0) > 0 && (
                  <div className="dept-stat" style={{ color: '#EF4444' }}>
                    <AlertTriangle size={14} />
                    <span>{dept.escalatedCount} Escalated!</span>
                  </div>
                )}
              </div>

              {/* Expanded: HOD Info */}
              {selectedDept === dept.id && (
                <div className="dept-page-expanded fade-in">
                  <div className="dept-hod-section">
                    <div className="dept-hod-header">
                      <h4>👤 Head of Department</h4>
                      {isSupervisor && (
                        <button className="btn-icon" onClick={() => startEditHod(dept)} title="Edit HOD">
                          <Edit3 size={14} />
                        </button>
                      )}
                    </div>

                    {editingHod === dept.id ? (
                      <div className="dept-hod-edit">
                        <input
                          className="form-input form-input-sm"
                          placeholder="HOD Name"
                          value={hodForm.hodName}
                          onChange={e => setHodForm({...hodForm, hodName: e.target.value})}
                        />
                        <input
                          className="form-input form-input-sm"
                          placeholder="Title (e.g. Chief Engineer)"
                          value={hodForm.hodTitle}
                          onChange={e => setHodForm({...hodForm, hodTitle: e.target.value})}
                        />
                        <input
                          className="form-input form-input-sm"
                          placeholder="Email"
                          value={hodForm.hodEmail}
                          onChange={e => setHodForm({...hodForm, hodEmail: e.target.value})}
                        />
                        <input
                          className="form-input form-input-sm"
                          placeholder="Phone"
                          value={hodForm.hodPhone}
                          onChange={e => setHodForm({...hodForm, hodPhone: e.target.value})}
                        />
                        <div style={{ display: 'flex', gap: 8, marginTop: 8 }}>
                          <button className="btn btn-primary btn-sm" onClick={() => handleHodSave(dept.id)}>Save</button>
                          <button className="btn btn-ghost btn-sm" onClick={() => setEditingHod(null)}>Cancel</button>
                        </div>
                      </div>
                    ) : (
                      <div className="dept-hod-info">
                        <div className="dept-hod-row">
                          <User size={14} />
                          <span className="dept-hod-name">{dept.hodName || 'Not assigned'}</span>
                          {dept.hodTitle && <span className="dept-hod-title">• {dept.hodTitle}</span>}
                        </div>
                        {dept.hodEmail && (
                          <div className="dept-hod-row">
                            <Mail size={14} />
                            <a href={`mailto:${dept.hodEmail}`} className="dept-hod-link">{dept.hodEmail}</a>
                          </div>
                        )}
                        {dept.hodPhone && (
                          <div className="dept-hod-row">
                            <Phone size={14} />
                            <a href={`tel:${dept.hodPhone}`} className="dept-hod-link">{dept.hodPhone}</a>
                          </div>
                        )}
                      </div>
                    )}
                  </div>

                  {/* Issue Breakdown */}
                  <div className="dept-breakdown">
                    <h4>📊 Issue Breakdown</h4>
                    <div className="dept-bar-container">
                      {[
                        { label: 'Pending', count: dept.pendingCount, color: '#F59E0B' },
                        { label: 'In Progress', count: dept.inProgressCount, color: '#3B82F6' },
                        { label: 'Verification', count: dept.pendingVerificationCount, color: '#8B5CF6' },
                        { label: 'Resolved', count: dept.resolvedCount, color: '#10B981' },
                      ].map(s => (
                        <div key={s.label} className="dept-bar-row">
                          <span className="dept-bar-label">{s.label}</span>
                          <div className="dept-bar-track">
                            <div
                              className="dept-bar-fill"
                              style={{
                                width: `${dept.totalIssues > 0 ? (s.count / dept.totalIssues) * 100 : 0}%`,
                                background: s.color,
                              }}
                            />
                          </div>
                          <span className="dept-bar-count" style={{ color: s.color }}>{s.count || 0}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}
```

