// ─── Seed Script v3 ───
// Seeds 5 departments with HOD info

import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

const departments = [
  {
    name: 'Public Works & Roads',
    slug: 'public-works-roads',
    icon: '🚧',
    color: '#F59E0B',
    description: 'Potholes, road damage, drainage, bridges, footpath repairs, and general infrastructure maintenance.',
    hodName: 'Ramesh Kumar Sharma',
    hodEmail: 'hod.roads@municipal.gov.in',
    hodPhone: '+91-141-2227001',
    hodTitle: 'Chief Engineer (Roads)',
  },
  {
    name: 'Water & Sewerage',
    slug: 'water-sewerage',
    icon: '💧',
    color: '#0EA5E9',
    description: 'Water supply disruptions, pipeline leaks, sewage overflow, water contamination, and bore-well issues.',
    hodName: 'Priya Verma',
    hodEmail: 'hod.water@municipal.gov.in',
    hodPhone: '+91-141-2227002',
    hodTitle: 'Superintendent Engineer (Water)',
  },
  {
    name: 'Electricity & Street Lighting',
    slug: 'electricity-lighting',
    icon: '⚡',
    color: '#EAB308',
    description: 'Street light outages, exposed wiring, transformer failures, power fluctuations, and electrical hazards.',
    hodName: 'Vikram Singh Rathore',
    hodEmail: 'hod.electricity@municipal.gov.in',
    hodPhone: '+91-141-2227003',
    hodTitle: 'Executive Engineer (Electrical)',
  },
  {
    name: 'Sanitation & Waste Management',
    slug: 'sanitation-waste',
    icon: '🗑️',
    color: '#10B981',
    description: 'Garbage collection delays, overflowing bins, illegal dumping, drain cleaning, and public toilet maintenance.',
    hodName: 'Anjali Mehra',
    hodEmail: 'hod.sanitation@municipal.gov.in',
    hodPhone: '+91-141-2227004',
    hodTitle: 'Health Officer (Sanitation)',
  },
  {
    name: 'Parks & Public Spaces',
    slug: 'parks-public-spaces',
    icon: '🌳',
    color: '#22C55E',
    description: 'Park maintenance, tree trimming, playground safety, public bench repairs, and green area upkeep.',
    hodName: 'Deepak Choudhary',
    hodEmail: 'hod.parks@municipal.gov.in',
    hodPhone: '+91-141-2227005',
    hodTitle: 'Director (Horticulture)',
  },
];

async function main() {
  console.log('🌱 Seeding database v3...');

  // Upsert departments (idempotent — safe to run multiple times)
  for (const dept of departments) {
    await prisma.department.upsert({
      where: { slug: dept.slug },
      update: dept,
      create: dept,
    });
  }

  console.log(`✅ ${departments.length} departments seeded with HOD info`);

  // Remove old departments that are no longer in the list
  const validSlugs = departments.map((d) => d.slug);
  const deleted = await prisma.department.deleteMany({
    where: { slug: { notIn: validSlugs } },
  });
  if (deleted.count > 0) {
    console.log(`🗑️  Removed ${deleted.count} old departments`);
  }

  console.log('🎉 Seeding complete!');
}

main()
  .catch((e) => {
    console.error('❌ Seed error:', e);
    process.exit(1);
  })
  .finally(() => prisma.$disconnect());

