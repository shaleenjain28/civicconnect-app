# CivicConnect v3 — Accountability Overhaul Walkthrough

## Summary
Transformed CivicConnect from a basic complaint board into an **accountability-driven civic management system** with department-specific HOD assignment, deadline enforcement, and resolution verification.

---

## 🗄️ Database (Prisma + Supabase)

### Schema Changes
- **5 Core Departments** with HOD contact fields: `hodName`, `hodEmail`, `hodPhone`, `hodTitle`
  - 🛣️ Public Works & Roads
  - 🚰 Water & Sewerage  
  - ⚡ Electricity & Street Lighting
  - 🗑️ Sanitation & Waste Management
  - 🌳 Parks & Public Spaces

- **Issue Model** — new fields:
  - `deadline` — auto-calculated (Critical: 24h, High: 3d, Medium/Low: 7d)
  - `urgencyScore` — weighted algorithm (upvotes + dept weight + deadline penalty)
  - `criticality` — critical/high/medium/low
  - `escalated` — auto-set when deadline passes
  - `resolutionPhoto` / `resolutionNote` — for photo-verified resolution
  - `verifiedById` / `verifiedAt` — supervisor/citizen verification

```diff:schema.prisma
===
// ─── Prisma Schema v3 ───
// Accountability-driven civic issue management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User table ───
// Synced with Supabase Auth — id matches Supabase user UUID
model User {
  id           String      @id @default(uuid())
  email        String      @unique
  phone        String?     @unique
  name         String
  avatarUrl    String?     @map("avatar_url")
  role         String      @default("citizen") // citizen | municipal | supervisor | ngo
  language     String      @default("en")      // en | hi | gu
  departmentId Int?        @map("department_id") // only for municipal role
  createdAt    DateTime    @default(now())     @map("created_at")

  department    Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  issues        Issue[]      @relation("ReportedIssues")
  assignedIssues Issue[]    @relation("AssignedIssues")
  votes         Vote[]
  comments      Comment[]
  statusChanges StatusHistory[]
  verifications Issue[]     @relation("VerifiedIssues")

  @@map("users")
}

// ─── Department table ───
// 5 government departments with HOD contact info
model Department {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  slug        String  @unique
  icon        String
  color       String
  description String?

  // HOD — Head of Department (admin-managed, can't be edited by HOD)
  hodName     String?  @map("hod_name")
  hodEmail    String?  @map("hod_email")
  hodPhone    String?  @map("hod_phone")
  hodTitle    String?  @map("hod_title")  // e.g. "Commissioner", "Chief Engineer"

  issues Issue[]
  users  User[]  @relation("UserDepartment")

  @@map("departments")
}

// ─── Issue table ───
// Core entity — citizen-reported civic problems with accountability
model Issue {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  title           String
  description     String
  departmentId    Int       @map("department_id")
  scope           String    @default("local")    // local | city | state | country
  status          String    @default("pending")  // pending | in_progress | pending_verification | resolved | rejected
  criticality     String    @default("medium")   // critical | high | medium | low
  latitude        Float
  longitude       Float
  locationText    String?   @map("location_text")
  imageUrl        String?   @map("image_url")
  upvoteCount     Int       @default(0)          @map("upvote_count")
  urgencyScore    Int       @default(0)          @map("urgency_score")

  // Deadline & Escalation
  deadline        DateTime?
  escalated       Boolean   @default(false)

  // Assignment
  assignedToId    String?   @map("assigned_to")

  // Resolution
  resolutionPhoto String?   @map("resolution_photo")
  resolutionNote  String?   @map("resolution_note")
  verifiedById    String?   @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")

  createdAt       DateTime  @default(now())      @map("created_at")
  resolvedAt      DateTime?                      @map("resolved_at")

  user          User           @relation("ReportedIssues", fields: [userId], references: [id])
  assignedTo    User?          @relation("AssignedIssues", fields: [assignedToId], references: [id])
  verifiedBy    User?          @relation("VerifiedIssues", fields: [verifiedById], references: [id])
  department    Department     @relation(fields: [departmentId], references: [id])
  votes         Vote[]
  comments      Comment[]
  statusHistory StatusHistory[]

  @@map("issues")
}

// ─── Vote table ───
model Vote {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  issueId   Int      @map("issue_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@map("votes")
}

// ─── Comment table ───
model Comment {
  id         Int      @id @default(autoincrement())
  issueId    Int      @map("issue_id")
  userId     String   @map("user_id")
  body       String
  authorType String   @default("citizen") @map("author_type") // citizen | authority | supervisor
  createdAt  DateTime @default(now())     @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("comments")
}

// ─── Status History table ───
model StatusHistory {
  id        Int      @id @default(autoincrement())
  issueId   Int      @map("issue_id")
  oldStatus String   @map("old_status")
  newStatus String   @map("new_status")
  changedBy String   @map("changed_by")
  note      String?
  changedAt DateTime @default(now()) @map("changed_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [changedBy], references: [id])

  @@map("status_history")
}

```
