## Database Schema (Prisma)

```prisma
// schema.prisma — this is what Prisma schema looks like

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  citizen
  municipal
  ngo
}

enum IssueStatus {
  pending
  in_progress
  resolved
}

enum Criticality {
  critical
  high
  medium
  low
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  role      Role     @default(citizen)
  language  String   @default("en")
  createdAt DateTime @default(now()) @map("created_at")

  issues    Issue[]
  votes     Vote[]
  comments  Comment[]
  statusChanges StatusHistory[]

  @@map("users")
}

model Department {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  slug        String  @unique
  icon        String
  color       String
  description String?
  issues      Issue[]

  @@map("departments")
}

model Issue {
  id           Int          @id @default(autoincrement())
  userId       String       @map("user_id")
  title        String
  description  String
  departmentId Int          @map("department_id")
  scope        String       @default("local")
  status       IssueStatus  @default(pending)
  criticality  Criticality  @default(medium)
  latitude     Float
  longitude    Float
  locationText String?      @map("location_text")
  imageUrl     String?      @map("image_url")
  upvoteCount  Int          @default(0) @map("upvote_count")
  createdAt    DateTime     @default(now()) @map("created_at")
  resolvedAt   DateTime?    @map("resolved_at")

  user         User         @relation(fields: [userId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])
  votes        Vote[]
  comments     Comment[]
  statusHistory StatusHistory[]

  @@map("issues")
}

model Vote {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  issueId   Int      @map("issue_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@map("votes")
}

model Comment {
  id         Int      @id @default(autoincrement())
  issueId    Int      @map("issue_id")
  userId     String   @map("user_id")
  body       String
  authorType String   @default("citizen") @map("author_type")
  createdAt  DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("comments")
}

model StatusHistory {
  id        Int      @id @default(autoincrement())
  issueId   Int      @map("issue_id")
  oldStatus String   @map("old_status")
  newStatus String   @map("new_status")
  changedBy String   @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [changedBy], references: [id])

  @@map("status_history")
}
